<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} — Choonie Chang</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Old+Standard+TT:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@400;500&family=Noto+Sans:wght@400;500;700&family=Inter:wght@400;500;700;800&family=Teko:wght@500&display=swap" rel="stylesheet">
    <link rel="icon" type="image/png" href="/images/fav.png">
    <link rel="preload" as="image" href="/images/fav.png">
    <link rel="stylesheet" href="/css/shared.css">
    <link rel="stylesheet" href="/css/transition.css">
    {% if pageCss %}<link rel="stylesheet" href="/css/{{ pageCss }}.css">{% endif %}
    <script>if(sessionStorage.getItem('page-transition')){document.documentElement.classList.add('transition-arriving')}</script>
</head>
<body>

<div class="page-transition">
    <div class="overlay">
        <img class="overlay-icon" src="/images/fav.png" alt="">
        <span class="overlay-text">Choonie Chang</span>
    </div>
</div>

{% include "nav.njk" %}

<div class="page">
<div class="content">
    {{ content | safe }}
    {% include "project-nav.njk" %}
    <div class="footer-spacer"></div>
</div>
</div>

<script src="/js/ba-slider.js"></script>
<script src="/js/transition.js"></script>
<script src="/js/page-nav.js"></script>
</body>
</html>
